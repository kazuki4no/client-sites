#!/bin/bash
# =====================================================
#  公開.command  —  client-sites を自動でGitHubに公開
#  （チーム共有版：アップロード前に自動で最新を取り込みます）
#  使い方：このファイルをダブルクリックするだけ
# =====================================================

# このスクリプトが置かれている場所（＝client-sitesフォルダ）に移動
cd "$(dirname "$0")"

echo "======================================"
echo "  サイト公開ツール（チーム共有版）"
echo "======================================"
echo ""
echo "作業フォルダ: $(pwd)"
echo ""

# gitリポジトリかどうか確認
if [ ! -d ".git" ]; then
  echo "⚠️  ここはgitリポジトリではないようです。"
  echo "    このファイルは client-sites フォルダの中に置いてください。"
  echo ""
  echo "（Enterキーで閉じます）"
  read
  exit 1
fi

# --- 1. 自分の変更を先に保存（コミット）する ---
if [ -n "$(git status --porcelain)" ]; then
  echo "📂 以下の変更を公開します："
  echo "--------------------------------------"
  git status --short
  echo "--------------------------------------"
  echo ""
  NOW=$(date "+%Y-%m-%d %H:%M")
  git add -A
  git commit -m "サイト更新 $NOW"
  echo ""
else
  echo "📭 新しい変更はありません（他の人の更新の取り込みだけ行います）。"
  echo ""
fi

# --- 2. 先にGitHubの最新を取り込む（他の人の更新を反映） ---
echo "🔄 他のメンバーの最新を取り込み中..."
if ! git pull --no-edit --no-rebase; then
  echo ""
  echo "⚠️  取り込み中に問題が発生しました（コンフリクトの可能性）。"
  echo "    同じファイルを複数人が同時に編集した場合に起きます。"
  echo "    この画面をスクショして相談してください。"
  echo ""
  echo "（Enterキーで閉じます）"
  read
  exit 1
fi
echo ""

# --- 3. アップロード（push） ---
echo "⏳ GitHubにアップロード中..."
echo ""
if git push; then
  echo ""
  echo "======================================"
  echo "✅ 公開が完了しました！"
  echo "======================================"
  echo ""
  echo "数分後、以下の形のURLで見られるようになります："
  echo "  https://（あなたのGitHubユーザー名）.github.io/client-sites/（フォルダ名）/（ファイル名）"
  echo ""
  echo "※ 反映に5〜10分かかることがあります。404の場合は少し待って再読み込みしてください。"
else
  echo ""
  echo "❌ アップロードに失敗しました。"
  echo "   ネット接続、またはGitHubのログイン設定を確認してください。"
  echo "   解決しない場合は、この画面をスクショして相談してください。"
fi

echo ""
echo "（Enterキーで閉じます）"
read
